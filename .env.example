# ──────────────────────────────────────────────────────────────────────────────
# .env.example — Todas as variáveis de ambiente do projeto
#
# Na EC2: copie este arquivo para um local seguro (ex: /home/ubuntu/.pw.env)
# e defina o caminho na secret ENV_FILE_PATH do GitHub.
#
# NÃO commitar o arquivo .env real.
# ──────────────────────────────────────────────────────────────────────────────

# Mailer (gmail)
CONTACT_EMAIL=
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Mailer (SES)
SES_REGION=
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
DOMAIN=
CONTACT_RECEIVER=

# Backend
PORT=4000
ALLOWED_ORIGINS=https://heloisarossato.com,https://www.heloisarossato.com

# Contact form (limit rate in seconds)
CONTACT_FORM_RATE_LIMIT_WINDOW=
CONTACT_FORM_MAX=

# Environment
NODE_ENV=
