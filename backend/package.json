{
    "name": "backend",
    "version": "1.0.0",
    "private": true,
    "description": "Personal website backend – Node.js + Express + TypeScript",
    "main": "dist/app.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
        "build": "tsc",
        "postbuild": "cp -r src/data dist/",
        "start": "node dist/app.js",
        "test": "vitest run",
        "lint": "eslint src --ext ts"
    },
    "dependencies": {
        "@aws-sdk/client-sesv2": "^3.1013.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.3",
        "express-rate-limit": "^7.2.0",
        "helmet": "^7.1.0",
        "nodemailer": "^8.0.3",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.12.5",
        "@types/nodemailer": "^7.0.11",
        "@types/supertest": "^6.0.2",
        "supertest": "^7.1.0",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.4.5",
        "vitest": "^3.1.1"
    }
}